{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "paths": {
      "@libs/prisma": [
        "libs/prisma/src/index.ts"
      ],
      "@libs/rabbitmq": [
        "libs/rabbitmq/src/index.ts"
      ],
      "@libs/common": [
        "libs/common/src/index.ts"
      ]
    }
  }
}